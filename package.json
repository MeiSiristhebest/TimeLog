{
  "name": "timelog",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "agent:dev": "agents\\.venv\\Scripts\\python.exe agents\\story_agent.py dev",
    "build:dev:ios": "eas build -p ios --profile development",
    "build:dev:android": "eas build -p android --profile development",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:json": "eslint \"**/*.{js,jsx,ts,tsx}\" -f json",
    "lint:baseline:write": "node scripts/eslint-warning-budget.mjs --write",
    "lint:baseline:check": "node scripts/eslint-warning-budget.mjs --check",
    "hardcode:audit": "node scripts/hardcode-audit.mjs",
    "hardcode:audit:baseline": "node scripts/hardcode-audit.mjs --baseline",
    "hardcode:audit:check": "node scripts/hardcode-audit.mjs --check --mode=error",
    "hardcode:audit:ci": "node scripts/hardcode-audit.mjs --check --mode=error",
    "copy:english:check": "node scripts/english-copy-guard.mjs",
    "perf:benchmark": "node scripts/perf-benchmark.mjs",
    "perf:device:report": "node scripts/device-perf-report.mjs",
    "security:rls:e2e": "node scripts/rls-e2e-check.mjs",
    "types:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-supabase-types.ps1",
    "lint:format": "prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "test": "jest",
    "test:integration": "jest tests/integration",
    "test:target": "jest -t"
  },
