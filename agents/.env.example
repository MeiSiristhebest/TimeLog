# Environment Variables for TimeLog Story Agent

# LiveKit Configuration
LIVEKIT_URL=wss://time-log-wuk3kw5e.livekit.cloud
LIVEKIT_API_KEY=API5pvKHSbvamGw
LIVEKIT_API_SECRET=your-livekit-secret-here

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Google Gemini (LLM) - Choose ONE option below:

# Option 1: Direct Gemini API (Simpler, good for development)
GEMINI_API_KEY=your-gemini-api-key-here
USE_VERTEX_AI=false

# Option 2: Vertex AI (Recommended for production)
# USE_VERTEX_AI=true
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Agent Configuration
AGENT_MIN_SILENCE_DURATION=3.0  # Elderly-tuned VAD (3-5 seconds)
AGENT_LANGUAGE=multi            # Multi-language support (Thai/English)
AGENT_TTS_MODEL=aura-asteria-en # Deepgram TTS model
